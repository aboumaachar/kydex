# KYDEX Production Environment Template
# Fill with production values from your secret manager.

NODE_ENV=production
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=https://your-domain/api/v1

DATABASE_URL=postgresql://user:password@db-host:5432/kydex

JWT_SECRET=replace-with-strong-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

CORS_ORIGIN_WHITELIST=https://your-domain,https://your-admin-domain
NOTARY_WIDGET_ALLOWED_ORIGINS=https://your-notary-site

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
NOTARY_KEY_DAILY_LIMIT=250
NOTARY_SITE_DAILY_LIMIT=300
NOTARY_IP_DAILY_LIMIT=500
NOTARY_AUTH_ABUSE_WINDOW_MS=900000
NOTARY_AUTH_ABUSE_THRESHOLD=12

MAX_UPLOAD_BYTES=10485760
KYDEX_ENABLE_HEIC=false

REDIS_HOST=redis
REDIS_PORT=6379

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=replace
MINIO_SECRET_KEY=replace
MINIO_BUCKET=kydex-files
MINIO_USE_SSL=false

OFAC_SYNC_TOKEN=replace
