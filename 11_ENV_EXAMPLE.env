# KYDEX Environment Example

NODE_ENV=development

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Database
DATABASE_URL=postgresql://kydex:kydex_dev_password@localhost:5432/kydex?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=kydex_minio
MINIO_SECRET_KEY=kydex_minio_password
MINIO_BUCKET=kydex-files
MINIO_USE_SSL=false

# Auth
JWT_SECRET=change_this_in_production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SMOKE_TEST_EMAIL=admin@kydex.local
SMOKE_TEST_PASSWORD=change_me
UPLOAD_DEBUG_LOGS=false

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
API_BODY_LIMIT=1mb
MAX_UPLOAD_BYTES=10485760
CORS_ORIGIN_WHITELIST=http://localhost:3000
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_RESET_TOKEN_TTL=15m
REQUIRE_2FA_FOR_PRIVILEGED=false
PASSWORD_RESET_DEBUG_TOKEN=true
BACKUP_ENCRYPTION_KEY=change_this_backup_key

# System
DEFAULT_TENANT_COUNTRY=LB
